# Shared metadata profile for horizontally scaled ChunkGate deployments.
# Pair this with an S3-compatible block backend.
CHUNKGATE_METADATA=postgres
CHUNKGATE_POSTGRES_DSN=postgres://chunkgate:CHANGEME@postgres:5432/chunkgate?sslmode=require
CHUNKGATE_POSTGRES_MAX_OPEN_CONNS=16
CHUNKGATE_POSTGRES_MAX_IDLE_CONNS=4
CHUNKGATE_POSTGRES_CONN_MAX_LIFETIME_SECONDS=1800
