# Production-oriented OpenStack Swift backend profile.
# Replace every CHANGEME value before use.
CHUNKGATE_LISTEN=:8080
CHUNKGATE_DATA_DIR=/data
CHUNKGATE_METADATA=sqlite
CHUNKGATE_BACKEND=swift
CHUNKGATE_LOCAL_CAPACITY_BYTES=21474836480
CHUNKGATE_SCRATCH_MIN_FREE_BYTES=1073741824

CHUNKGATE_ACCESS_KEY_ID=CHANGEME_CLIENT_ACCESS_KEY
CHUNKGATE_SECRET_ACCESS_KEY=CHANGEME_CLIENT_SECRET_KEY
CHUNKGATE_TENANT_ID=default

CHUNKGATE_SWIFT_AUTH_URL=https://openstack.example.com:5000/v3
CHUNKGATE_SWIFT_USERNAME=chunkgate
CHUNKGATE_SWIFT_PASSWORD=CHANGEME_OPENSTACK_PASSWORD
CHUNKGATE_SWIFT_PROJECT_NAME=service
CHUNKGATE_SWIFT_DOMAIN_NAME=Default
CHUNKGATE_SWIFT_REGION=RegionOne
CHUNKGATE_SWIFT_CONTAINER=chunkgate-blocks
CHUNKGATE_SWIFT_AUTH=password
CHUNKGATE_SWIFT_TIMEOUT_SECONDS=30
CHUNKGATE_SWIFT_MAX_RETRIES=3

# Optional:
# CHUNKGATE_SWIFT_PROJECT_ID=CHANGEME_PROJECT_ID
# CHUNKGATE_SWIFT_ENDPOINT=https://swift.example.com/v1/AUTH_project_id/
# CHUNKGATE_SWIFT_PREFIX=prod/
# CHUNKGATE_SWIFT_INSECURE_SKIP_VERIFY=false
#
# Application credential auth:
# CHUNKGATE_SWIFT_AUTH=application-credential
# CHUNKGATE_SWIFT_APPLICATION_CREDENTIAL_ID=CHANGEME_APP_CRED_ID
# CHUNKGATE_SWIFT_APPLICATION_CREDENTIAL_SECRET=CHANGEME_APP_CRED_SECRET

CHUNKGATE_GC_ENABLED=true
CHUNKGATE_GC_INTERVAL_SECONDS=3600
CHUNKGATE_GC_MIN_ORPHAN_AGE_SECONDS=86400
CHUNKGATE_READINESS_TIMEOUT_SECONDS=3
CHUNKGATE_SHUTDOWN_TIMEOUT_SECONDS=15
