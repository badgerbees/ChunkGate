# Production-oriented Google Cloud Storage backend profile.
# Replace every CHANGEME value before use.
CHUNKGATE_LISTEN=:8080
CHUNKGATE_DATA_DIR=/data
CHUNKGATE_METADATA=sqlite
CHUNKGATE_BACKEND=gcs
CHUNKGATE_LOCAL_CAPACITY_BYTES=21474836480
CHUNKGATE_SCRATCH_MIN_FREE_BYTES=1073741824

CHUNKGATE_ACCESS_KEY_ID=CHANGEME_CLIENT_ACCESS_KEY
CHUNKGATE_SECRET_ACCESS_KEY=CHANGEME_CLIENT_SECRET_KEY
CHUNKGATE_TENANT_ID=default

CHUNKGATE_GCS_PROJECT_ID=CHANGEME_GCP_PROJECT
CHUNKGATE_GCS_BUCKET=chunkgate-blocks
CHUNKGATE_GCS_AUTH=service-account
CHUNKGATE_GCS_CREDENTIALS_FILE=/run/secrets/chunkgate-gcs-service-account.json
CHUNKGATE_GCS_TIMEOUT_SECONDS=30
CHUNKGATE_GCS_MAX_RETRIES=3

# Optional:
# CHUNKGATE_GCS_PREFIX=prod/
# CHUNKGATE_GCS_AUTH=default
# CHUNKGATE_GCS_CREDENTIALS_JSON={"type":"service_account",...}
# CHUNKGATE_GCS_ENDPOINT=http://fake-gcs-server:4443/storage/v1/
# CHUNKGATE_GCS_AUTH=emulator

CHUNKGATE_GC_ENABLED=true
CHUNKGATE_GC_INTERVAL_SECONDS=3600
CHUNKGATE_GC_MIN_ORPHAN_AGE_SECONDS=86400
CHUNKGATE_READINESS_TIMEOUT_SECONDS=3
CHUNKGATE_SHUTDOWN_TIMEOUT_SECONDS=15
