# Local curl-only development profile.
# Do not use anonymous mode on an untrusted network.
CHUNKGATE_LISTEN=:8080
CHUNKGATE_DATA_DIR=data
CHUNKGATE_BACKEND=filesystem
CHUNKGATE_ALLOW_ANONYMOUS=true
CHUNKGATE_LOCAL_CAPACITY_BYTES=21474836480
CHUNKGATE_SCRATCH_MIN_FREE_BYTES=1073741824

# Optional S3/browser compatibility helpers.
# CHUNKGATE_VIRTUAL_HOSTS=localhost
# CHUNKGATE_CORS_ALLOWED_ORIGINS=http://localhost:3000
