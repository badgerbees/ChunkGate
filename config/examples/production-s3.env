# Production-oriented S3-compatible backend profile.
# Replace every CHANGEME value before use.
CHUNKGATE_LISTEN=:8080
CHUNKGATE_DATA_DIR=/data
CHUNKGATE_METADATA=sqlite
CHUNKGATE_BACKEND=s3
CHUNKGATE_LOCAL_CAPACITY_BYTES=21474836480
CHUNKGATE_SCRATCH_MIN_FREE_BYTES=1073741824

CHUNKGATE_ACCESS_KEY_ID=CHANGEME_CLIENT_ACCESS_KEY
CHUNKGATE_SECRET_ACCESS_KEY=CHANGEME_CLIENT_SECRET_KEY
CHUNKGATE_TENANT_ID=default

CHUNKGATE_S3_ENDPOINT=CHANGEME_S3_ENDPOINT
CHUNKGATE_S3_REGION=us-east-1
CHUNKGATE_S3_BUCKET=chunkgate-blocks
CHUNKGATE_S3_ACCESS_KEY_ID=CHANGEME_BACKEND_ACCESS_KEY
CHUNKGATE_S3_SECRET_ACCESS_KEY=CHANGEME_BACKEND_SECRET_KEY
CHUNKGATE_S3_PATH_STYLE=true
CHUNKGATE_S3_USE_TLS=true
# Supabase Storage S3 is supported directly with its base-path endpoint:
# CHUNKGATE_S3_ENDPOINT=https://project_ref.storage.supabase.co/storage/v1/s3

# Optional public endpoint compatibility.
# Use this when clients address buckets as https://bucket.s3.example.com/key.
# CHUNKGATE_VIRTUAL_HOSTS=s3.example.com
# CHUNKGATE_CORS_ALLOWED_ORIGINS=https://app.example.com
# CHUNKGATE_CORS_ALLOWED_METHODS=GET,HEAD,PUT,POST,DELETE
# CHUNKGATE_CORS_ALLOWED_HEADERS=authorization,x-amz-date,x-amz-content-sha256,content-type
# CHUNKGATE_CORS_EXPOSED_HEADERS=ETag,x-amz-request-id,Content-Length,Content-Range

CHUNKGATE_GC_ENABLED=true
CHUNKGATE_GC_INTERVAL_SECONDS=3600
CHUNKGATE_GC_MIN_ORPHAN_AGE_SECONDS=86400
CHUNKGATE_READINESS_TIMEOUT_SECONDS=3
CHUNKGATE_SHUTDOWN_TIMEOUT_SECONDS=15
